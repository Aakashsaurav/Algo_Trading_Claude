# ============================================================
# .env.example — Copy this to .env and fill in your values
# NEVER commit .env to Git. Add .env to your .gitignore file.
# ============================================================

# --- Upstox API Credentials ---
# Get these from: https://account.upstox.com/developer/apps
UPSTOX_API_KEY="c6874704-5a01-4a76-b892-bede6f7a41cf"
UPSTOX_API_SECRET="o8v89kc8ff"
UPSTOX_REDIRECT_URI=https://127.0.0.1:5000/

# --- Token Storage ---
# Path where the access token will be saved after login
TOKEN_FILE_PATH=broker/upstox/token.json

# --- Capital & Risk Settings ---
TOTAL_CAPITAL=500000          # Starting capital in INR (5 Lakhs)
MAX_PORTFOLIO_DRAWDOWN=20.0   # Hard stop at 20% drawdown from peak
PER_TRADE_RISK_PERCENT=1.5    # Risk 1.5% of capital per trade

# --- Application Settings ---
PAPER_TRADE=True              # True = paper trade, False = real orders (be careful!)
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR

# --- Notification Settings (optional, set up later) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
